{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Jira Taskbar",
  "version": "0.1.0",
  "identifier": "com.jirataskbar.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Jira Taskbar",
        "width": 450,
        "height": 700,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "skipTaskbar": true,
        "decorations": true,
        "alwaysOnTop": true,
        "focus": false,
        "x": 100,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "./entitlements.plist"
    }
  }
}
